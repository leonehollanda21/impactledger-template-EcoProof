# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="EcoProof API"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=your-super-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 dias

# ── Banco de dados (PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://<user>:<password>@localhost:5432/ecoproof
DATABASE_URL_SYNC=postgresql://<user>:<password>@localhost:5432/ecoproof

# ── Cloudinary (armazenamento de imagens e metadata NFT) ──────────────────────
# Crie conta gratuita em https://cloudinary.com → Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Google Gemini AI (validação de imagens de limpeza) ────────────────────────
# Grátis: 1500 req/dia — pegue em https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key

# ── Web3 / Blockchain ─────────────────────────────────────────────────────────
# Defina BLOCKCHAIN_ENABLED=true para usar blockchain real.
# Sem isso, o sistema opera em modo simulado (gera tx_hash fake).

# Provider RPC — Polygon Amoy testnet (público e gratuito):
WEB3_PROVIDER_URL=https://rpc-amoy.polygon.technology/

# Endereços dos contratos (Proxies UUPS — use o endereço do PROXY, não da implementação)
NFT_CONTRACT_ADDRESS=0x...            # EcoProofNFT.sol (limpeza individual + eventos)
INSTITUTO_NFT_CONTRACT_ADDRESS=0x... # InstitutoNFT.sol
REGISTRY_CONTRACT_ADDRESS=0x...      # EcoProofRegistry.sol (ValidationRegistry)
DENUNCIA_NFT_ADDRESS=0x...           # DenunciaNFT.sol (ECFD — Fiscal Ambiental Soulbound)
EDUCACAO_NFT_ADDRESS=0x...           # EducacaoNFT.sol (ECED — Soulbound de Educação)
REGISTRY_ADDRESS=0x...               # EcoProofRegistry.sol (ValidationRegistry)
                                     # ↑ Deploy com: npx hardhat deploy --network amoy
                                     #   após compilar: npx hardhat compile

# Carteira do minter (backend assina as transações)
# ATENÇÃO: NUNCA commitar a chave real. Use variável de ambiente em produção.
MINTER_PRIVATE_KEY=0x...your-minter-wallet-private-key

# true = envia txs reais | false = modo simulado (hashes fake)
BLOCKCHAIN_ENABLED=false

# Chain ID: 80002=Polygon Amoy | 137=Polygon Mainnet | 31337=Hardhat local
CHAIN_ID=80002

# ── CORS ──────────────────────────────────────────────────────────────────────
# Desenvolvimento: ["*"]
# Produção: ["https://app.ecoproof.io","https://ecoproof.io"]
CORS_ORIGINS=["*"]
